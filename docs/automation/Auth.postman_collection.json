        {
          "name": "Login Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status là 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response chứa status = true\", function () {\r",
                  "    pm.expect(res.status).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response chứa token\", function () {\r",
                  "    pm.expect(res).to.have.property(\"token\");\r",
                  "    pm.expect(res.token).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response chứa user object\", function () {\r",
                  "    pm.expect(res).to.have.property(\"user\");\r",
                  "    pm.expect(res.user).to.be.an(\"object\");\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"token\", pm.response.json().token);\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
