    {
      "name": "Specific Author",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const role = pm.environment.get(\"role\");\r",
              "const code = pm.response.code;\r",
              "\r",
              "pm.test(\"Lấy author cụ thể\", function () {\r",
              "    const author = pm.response.json();\r",
              "\r",
              "    pm.expect(author).to.be.an('object');\r",
              "    pm.expect(author).to.have.property('id');\r",
              "    pm.expect(author).to.have.property('name');\r",
              "\r",
              "    // nếu API bạn có thêm field thì giữ, không thì xoá\r",
              "    pm.expect(author).to.have.property('is_active');\r",
              "});\r",
              "\r",
              "pm.test(\"Lấy author đã bị inactive\", function () {\r",
              "    if (role === \"admin\") {\r",
              "        pm.expect(code).to.eql(200);\r",
              "    } else {\r",
              "        pm.expect(code).to.eql(404);\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
