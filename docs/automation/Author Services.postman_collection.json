      "name": "Create Author",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const payload = {\r",
              "    \"name\": \"Nguyễn Nhật Ánh\",\r",
              "    \"date_of_birth\": \"1955-05-07\",\r",
              "    \"biography\": \"Nhà văn nổi tiếng Việt Nam\"\r",
              "};\r",
              "\r",
              "pm.environment.set(\"payload\", JSON.stringify(payload));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.environment.get(\"role\") === \"admin\") {\r",
              "    pm.test(\"Create author thành công\", function () {\r",
              "        const res = pm.response.json();\r",
              "\r",
              "        pm.response.to.have.status(201);\r",
              "\r",
              "        pm.expect(res).to.have.property(\"message\");\r",
              "        pm.expect(res).to.have.property(\"data\");\r",
              "\r",
              "        pm.expect(res.data).to.have.property(\"id\");\r",
              "        pm.expect(res.data).to.have.property(\"name\");\r",
              "    });\r",
              "} else {\r",
              "    pm.test(\"User không được tạo author\", function () {\r",
              "        pm.expect(pm.response.code).to.be.oneOf([401, 403]);\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
