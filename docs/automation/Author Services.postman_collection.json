        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Check danh sách author theo role\", function () {\r",
              "    const role = pm.environment.get(\"role\");\r",
              "    const res = pm.response.json();\r",
              "\r",
              "    pm.response.to.have.status(200);\r",
              "\r",
              "    pm.expect(res).to.have.property(\"results\");\r",
              "\r",
              "    const authors = res.results;\r",
              "\r",
              "    pm.expect(authors).to.be.an(\"array\");\r",
              "\r",
              "    if (role === \"admin\") {\r",
              "        pm.expect(authors.length).to.be.greaterThan(0);\r",
              "    } \r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
