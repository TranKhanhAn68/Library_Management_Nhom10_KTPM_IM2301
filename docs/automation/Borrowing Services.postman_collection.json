    {
      "name": "List Borrowing",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const role = pm.environment.get(\"role\");\r",
              "\r",
              "pm.test(\"List borrowing\", function () {\r",
              "    const res = pm.response.json();\r",
              "\r",
              "    pm.response.to.have.status(200);\r",
              "    pm.expect(res).to.have.property(\"results\");\r",
              "\r",
              "    const borrows = res.results;\r",
              "\r",
              "    pm.expect(borrows).to.be.an(\"array\");\r",
              "\r",
              "    if (role === \"admin\") {\r",
              "        pm.expect(borrows.length).to.be.greaterThan(0);\r",
              "    } else {\r",
              "        borrows.forEach(b => {\r",
              "            pm.expect(b).to.have.property(\"user\");\r",
              "        });\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "token {{token}}",
