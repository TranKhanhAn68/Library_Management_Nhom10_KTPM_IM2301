    {
      "name": "Search Category",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const categories = pm.response.json();\r",
              "const query = pm.request.url.query.get(\"search\");\r",
              "\r",
              "pm.test(\"Trả về danh sách Categories\", function () {\r",
              "    pm.expect(categories).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Có kết quả chứa name\", function () {\r",
              "    const found = categories.some(cat =>\r",
              "        cat.name.includes(query)\r",
              "    );\r",
              "\r",
              "    pm.expect(found).to.be.true;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
