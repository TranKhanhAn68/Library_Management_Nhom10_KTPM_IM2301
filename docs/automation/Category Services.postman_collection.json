    {
      "name": "List Category",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const role = pm.environment.get(\"role\");\r",
              "\r",
              "pm.test(\"List category theo role\", function () {\r",
              "    const res = pm.response.json();\r",
              "\r",
              "    pm.response.to.have.status(200);\r",
              "    pm.expect(res).to.have.property(\"results\");\r",
              "\r",
              "    const categories = res.results;\r",
              "\r",
              "    pm.expect(categories).to.be.an(\"array\");\r",
              "\r",
              "    if (role === \"admin\") {\r",
              "        pm.expect(categories.length).to.be.greaterThan(0);\r",
              "    } else {\r",
              "        categories.forEach(cate => {\r",
              "            pm.expect(cate.is_active).to.eql(true);\r",
              "        });\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
