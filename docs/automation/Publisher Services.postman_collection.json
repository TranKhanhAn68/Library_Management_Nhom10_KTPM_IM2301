    {
      "name": "Specific Publisher",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const role = pm.environment.get(\"role\");\r",
              "const code = pm.response.code;\r",
              "\r",
              "pm.test(\"Lấy publisher cụ thể\", function () {\r",
              "    if (code === 200) {\r",
              "        const json = pm.response.json();\r",
              "\r",
              "        pm.expect(json).to.be.an(\"object\");\r",
              "        pm.expect(json).to.have.property(\"id\");\r",
              "        pm.expect(json).to.have.property(\"name\");\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"Publisher inactive\", function () {\r",
              "    if (role === \"admin\") {\r",
              "        pm.expect(code).to.eql(200);\r",
              "    } else {\r",
              "        pm.expect(code).to.eql(404);\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
