          "listen": "test",
          "script": {
            "exec": [
              "const role = pm.environment.get(\"role\");\r",
              "\r",
              "pm.test(\"List reservation theo role\", function () {\r",
              "    const code = pm.response.code;\r",
              "\r",
              "    if (role === \"admin\" || role === \"staff\") {\r",
              "        const res = pm.response.json();\r",
              "\r",
              "        pm.expect(code).to.eql(200);\r",
              "        pm.expect(res).to.have.property(\"results\");\r",
              "        pm.expect(res.results).to.be.an(\"array\");\r",
              "\r",
              "    } else {\r",
              "        // user bị chặn\r",
              "        pm.expect(code).to.eql(403);\r",
              "    }\r",
              "});"
            ],
