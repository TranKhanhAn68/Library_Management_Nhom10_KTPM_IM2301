  "item": [
    {
      "name": "Create Reservation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const role = pm.environment.get(\"role\");\r",
              "const res = pm.response.json();\r",
              "\r",
              "pm.test(\"Create reservation theo role\", function () {\r",
              "\r",
              "    if (role === \"user\") {\r",
              "        pm.response.to.have.status(201);\r",
              "        pm.expect(res).to.have.property(\"message\");\r",
              "\r",
              "    } else if (role === \"admin\" || role === \"staff\") {\r",
              "        // staff vẫn tạo được (do IsAuthenticated)\r",
              "        pm.response.to.have.status(201);\r",
              "\r",
              "    } else {\r",
              "        pm.expect(pm.response.code).to.be.oneOf([401, 403]);\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
