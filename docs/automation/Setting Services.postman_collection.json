    {
      "name": "List Setting",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Lấy settings thành công\", function () {\r",
              "    const res = pm.response.json();\r",
              "\r",
              "    pm.response.to.have.status(200);\r",
              "    pm.expect(res).to.have.property(\"results\");\r",
              "\r",
              "    const settings = res.results;\r",
              "    pm.expect(settings).to.be.an(\"array\");\r",
              "\r",
              "    if (settings.length > 0) {\r",
              "        pm.expect(settings[0]).to.have.property(\"borrowing_days\");\r",
              "        pm.expect(settings[0]).to.have.property(\"borrowing_fee\");\r",
              "        pm.expect(settings[0]).to.have.property(\"borrowing_overdue_fine\");\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
