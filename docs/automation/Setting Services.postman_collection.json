          "listen": "test",
          "script": {
            "exec": [
              "const role = pm.environment.get(\"role\");\r",
              "\r",
              "pm.test(\"Create setting theo role\", function () {\r",
              "    if (role === \"admin\") {\r",
              "        const json = pm.response.json();\r",
              "\r",
              "        pm.response.to.have.status(201);\r",
              "        pm.expect(json).to.have.property(\"id\");\r",
              "        pm.expect(json.borrowing_days).to.eql(10);\r",
              "    } else {\r",
              "        pm.expect(pm.response.code).to.be.oneOf([401, 403]);\r",
              "    }\r",
              "});"
