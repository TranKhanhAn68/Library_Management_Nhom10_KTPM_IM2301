        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "role = pm.environment.set(\"role\", \"user\")\r",
          "role = pm.environment.get(\"role\");\r",
          "if (role === \"admin\") {\r",
          "    pm.environment.set(\"token\", pm.environment.get(\"admin_token\"));\r",
          "} else {\r",
          "    pm.environment.set(\"token\", pm.environment.get(\"user_token\"))\r",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "pm.test(\"Status code theo role + method\", function () {\r",
          "    const role = pm.environment.get(\"role\");\r",
          "    const code = pm.response.code;\r",
          "    const method = pm.request.method;\r",
          "\r",
          "    if (method === \"GET\") {\r",
          "        pm.expect(code).to.be.oneOf([200, 404]);\r",
          "    } else {\r",
          "        if (role === \"admin\") {\r",
          "            pm.expect(code).to.be.oneOf([200, 201, 204]);\r",
          "        } else {\r",
          "            pm.expect(code).to.be.oneOf([401, 403]);\r",
          "        }\r",
          "    }\r",
          "});"
        ]
      }
    }
